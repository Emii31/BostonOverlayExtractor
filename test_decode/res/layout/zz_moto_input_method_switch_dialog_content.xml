<?xml version="1.0" encoding="utf-8"?>
<LinearLayout android:orientation="vertical" android:layout_width="match_parent" android:layout_height="wrap_content"
  xmlns:android="http://schemas.android.com/apk/res/android">
    <ScrollView android:layout_width="wrap_content" android:layout_height="wrap_content">
        <LinearLayout android:orientation="vertical" android:layout_width="match_parent" android:layout_height="wrap_content">
            <LinearLayout android:orientation="vertical" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="20.0px" android:paddingStart="40.0px" android:paddingEnd="40.0px">
                <TextView android:textSize="40.0px" android:textStyle="bold" android:ellipsize="end" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="10.0px" android:text="@string/zz_moto_input_prompt_title" android:singleLine="true" android:paddingStart="5.0dp" />
                <TextView android:textSize="34.0px" android:id="@id/prompt_content" android:paddingBottom="10.0px" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/zz_moto_input_prompt_message" android:paddingStart="10.0px" />
                <CheckBox android:textSize="32.0px" android:id="@id/alwaysUse" android:focusable="true" android:clickable="true" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/zz_moto_input_prompt_check" />
            </LinearLayout>
            <LinearLayout android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content" android:paddingStart="20.0px" android:paddingEnd="20.0px">
                <Button android:textSize="34.0px" android:id="@id/button1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/zz_moto_input_prompt_cancel" style="?buttonBarButtonStyle" />
                <Button android:textSize="34.0px" android:id="@id/button2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/zz_moto_input_prompt_confirm" style="?buttonBarButtonStyle" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
